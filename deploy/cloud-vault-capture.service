[Unit]
Description=Cloud Vault Browser Capture API
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/cloud-vault-browser-capture/backend
EnvironmentFile=/opt/cloud-vault-browser-capture/backend/.env
ExecStart=/opt/cloud-vault-browser-capture/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
